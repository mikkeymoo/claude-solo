{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash list*)",
      "Bash(git remote *)",
      "Bash(rtk *)",
      "Bash(ls *)",
      "Bash(node --version)",
      "Bash(python --version)",
      "Bash(npm --version)",
      "Bash(pnpm --version)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(npm publish *)",
      "Bash(cargo publish *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(curl * | sh)",
      "Bash(dd if=*)",
      "Bash(chmod -R 777 *)",
      "Bash(mkfs.*)"
    ]
  },

  "enableAllProjectMcpServers": false,

  "env": {
    "CLAUDE_SOLO_SAFE_MODE": "1"
  }
}
