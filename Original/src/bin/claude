#!/usr/bin/env bash
# claude-solo wrapper — cache-fix preload + safe mode support
# https://github.com/cnighswonger/claude-code-cache-fix
set -euo pipefail

# Resolve npm global prefix dynamically (works with nvm, brew, system npm, scoop)
NPM_PREFIX="$(npm config get prefix 2>/dev/null || echo "$HOME/.npm-global")"

# Fallback search order for claude-code CLI
_find_npm_module() {
  local mod="$1"
  local candidates=(
    "$NPM_PREFIX/lib/node_modules/$mod"
    "$HOME/.npm-global/lib/node_modules/$mod"
    "$HOME/.npm/lib/node_modules/$mod"
    "/usr/local/lib/node_modules/$mod"
    "/usr/lib/node_modules/$mod"
  )
  # Also check nvm active version
  if [ -n "${NVM_BIN:-}" ]; then
    candidates+=("$(dirname "$NVM_BIN")/lib/node_modules/$mod")
  fi
  for p in "${candidates[@]}"; do
    [ -e "$p" ] && echo "$p" && return 0
  done
  return 1
}

CLAUDE_PKG="$(_find_npm_module "@anthropic-ai/claude-code" 2>/dev/null || true)"
if [ -z "$CLAUDE_PKG" ] || [ ! -f "$CLAUDE_PKG/cli.js" ]; then
  echo "Error: Claude Code npm package not found." >&2
  echo "Install with: npm install -g @anthropic-ai/claude-code" >&2
  exit 1
fi
CLAUDE_NPM_CLI="$CLAUDE_PKG/cli.js"

CACHE_FIX_PKG="$(_find_npm_module "claude-code-cache-fix" 2>/dev/null || true)"
if [ -z "$CACHE_FIX_PKG" ] || [ ! -f "$CACHE_FIX_PKG/preload.mjs" ]; then
  echo "Error: claude-code-cache-fix not found." >&2
  echo "Install with: npm install -g claude-code-cache-fix" >&2
  exit 1
fi
CACHE_FIX_PRELOAD="$CACHE_FIX_PKG/preload.mjs"

# claude-code-cache-fix defaults (user-selected)
: "${CACHE_FIX_IMAGE_KEEP_LAST:=3}"
: "${CACHE_FIX_DEBUG:=0}"
: "${CACHE_FIX_USAGE_LOG:=$HOME/.claude/usage.jsonl}"
: "${CACHE_FIX_DUMP_TOOLS:=$HOME/.claude/cache-fix-tools.json}"

if [ -z "${CACHE_FIX_OUTPUT_EFFICIENCY_REPLACEMENT:-}" ]; then
  CACHE_FIX_OUTPUT_EFFICIENCY_REPLACEMENT="$(cat <<'EOF'
# Output efficiency

When sending user-facing text, write for a person, not a log file. Assume the user cannot see most tool calls or hidden reasoning - only your text output.

Keep user-facing text clear, direct, and reasonably concise. Lead with the answer or action. Skip filler, repetition, and unnecessary preamble.

Explain enough for the user to understand the reasoning, tradeoffs, or root cause when that would help them learn or make a decision, but do not turn simple answers into long writeups.

These instructions apply to user-facing text only. They do not apply to investigation, code reading, tool use, or verification.

Before making changes, read the relevant code and understand the surrounding context. Check types, signatures, call sites, and error causes before editing. Do not confuse brevity with rushing, and do not replace understanding with trial and error.

While working, give short updates at meaningful moments: when you find the root cause, when the plan changes, when you hit a blocker, or when a meaningful milestone is complete. Do not narrate every step.

When reporting results, be accurate and concrete. If you did not verify something, say so plainly. If a check failed, say that plainly too.
EOF
)"
fi

export CACHE_FIX_IMAGE_KEEP_LAST CACHE_FIX_DEBUG CACHE_FIX_USAGE_LOG CACHE_FIX_DUMP_TOOLS CACHE_FIX_OUTPUT_EFFICIENCY_REPLACEMENT

# Safe mode: claude --safe → restricted permissions, no auto project MCP, no additionalDirectories
SAFE_SETTINGS="$HOME/.claude/settings-safe.json"
EXTRA_ARGS=()
args=()
for arg in "$@"; do
  if [ "$arg" = "--safe" ]; then
    if [ -f "$SAFE_SETTINGS" ]; then
      EXTRA_ARGS+=(--settings "$SAFE_SETTINGS" --setting-sources "user")
      echo "🔒 Safe mode: no auto MCP, no additionalDirectories, read-only permissions need approval" >&2
    else
      echo "Warning: $SAFE_SETTINGS not found — running in normal mode" >&2
    fi
  else
    args+=("$arg")
  fi
done

if [ -n "${NODE_OPTIONS:-}" ]; then
  exec env NODE_OPTIONS="--import $CACHE_FIX_PRELOAD ${NODE_OPTIONS}" node "$CLAUDE_NPM_CLI" ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"} ${args[@]+"${args[@]}"}
else
  exec env NODE_OPTIONS="--import $CACHE_FIX_PRELOAD" node "$CLAUDE_NPM_CLI" ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"} ${args[@]+"${args[@]}"}
fi
