{
  "_comment_top": "Global settings — install to ~/.claude/settings.json. Hook scripts installed at ~/.claude/scripts/. Cross-platform: bash required (Git Bash on Windows). See README.md.",
  "_precedence": "Scope precedence (high → low): Managed > Local (.claude/settings.local.json) > Project (.claude/settings.json) > User (this file). Deny rules accumulate across all scopes; first match of deny > defer > ask > allow wins.",
  "model": "claude-sonnet-4-6",
  "effortLevel": "medium",
  "maxTurns": 200,
  "includeGitInstructions": true,
  "cleanupPeriodDays": 14,
  "attribution": {
    "_comment": "Replaces deprecated includeCoAuthoredBy. Turn off if you don't want Claude in your commit/PR trailers.",
    "commit": "auto",
    "pr": "auto"
  },
  "autoUpdatesChannel": "stable",
  "env": {
    "_comment": "Only vars verified against official Claude Code docs. cache-fix-wrapper exports CACHE_FIX_* separately — do NOT redefine those here. PYTHONIOENCODING + PYTHONUTF8: prevents charmap codec errors when Python stdout encounters Unicode (em-dashes, smart quotes, non-ASCII names in email/document parsing). CLAUDE_CODE_USE_POWERSHELL_TOOL: enables native PowerShell tool support on Windows.",
    "ENABLE_TOOL_SEARCH": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-haiku-4-5-20251001",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85",
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "0",
    "CLAUDE_CODE_DISABLE_BACKGROUND_TASKS": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_TELEMETRY": "1",
    "PYTHONIOENCODING": "utf-8",
    "PYTHONUTF8": "1",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "statusLine": {
    "_comment": "Optional statusline script. Remove this block if you don't have statusline.sh installed.",
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "permissions": {
    "_comment": "deny > ask > allow. Deny rules survive --dangerously-skip-permissions. Keep Bash(*) broad but rely on hooks (validate-bash.sh) for the hard blocks since deny-regex is string-match only.",
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "Bash(*)",
      "mcp__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Read(./*.pem)",
      "Read(./**/id_rsa)",
      "Read(./**/id_ed25519)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)",
      "Bash(bun publish*)",
      "Bash(cargo publish*)",
      "Bash(gem push*)",
      "Bash(twine upload*)"
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".next",
      "dist",
      "build",
      "__pycache__",
      ".venv",
      "target",
      ".pnpm-store"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "_comment": "1st: UTF-8 encoding bootstrap — must run first to set PYTHONIOENCODING before anything else",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/bootstrap-windows-encoding.sh",
            "statusMessage": "Bootstrapping Windows UTF-8 encoding...",
            "timeout": 5000
          }
        ]
      },
      {
        "_comment": "2nd: cost/cache summary from today's JSONL (throttled 5min)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/cost-summary.sh",
            "statusMessage": "Summarizing today's token usage...",
            "timeout": 10000
          }
        ]
      },
      {
        "_comment": "3rd: 5h quota window visibility (does not manipulate quota)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/quota-warmup-warn.sh",
            "statusMessage": "Checking quota window...",
            "timeout": 10000
          }
        ]
      },
      {
        "_comment": "4th: compact session HUD (throttled 10min)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/session-hud.sh",
            "statusMessage": "Loading session HUD...",
            "timeout": 10000
          }
        ]
      },
      {
        "_comment": "5th: git + sprint context injected into model context",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/session-start-context.sh",
            "statusMessage": "Loading git + sprint context...",
            "timeout": 10000
          }
        ]
      },
      {
        "_comment": "6th: Morae/eDiscovery context when CWD matches known project patterns",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/morae-context.sh",
            "statusMessage": "Checking project context...",
            "timeout": 5000
          }
        ]
      },
      {
        "_comment": "7th: daily update check (throttled 24h, network-failure-tolerant)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/update-check.sh",
            "statusMessage": "Checking for updates...",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/validate-readonly-query.sh"
          }
        ]
      },
      {
        "_comment": "Conventional commits enforcement + danger warnings + RTK auto-wrap",
        "matcher": "Bash|mcp__desktop-commander__start_process",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/pre-tool-use.js"
          }
        ]
      },
      {
        "_comment": "Block mojibake content before it corrupts files (exits 2 to block)",
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/validate-utf8-source.sh"
          }
        ]
      },
      {
        "_comment": "Warn when writing files > 500 lines or > 50KB (advisory, exit 0)",
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/large-file.js"
          }
        ]
      },
      {
        "_comment": "Warn when writing to typically-gitignored paths (advisory, exit 0)",
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/gitignore-check.js"
          }
        ]
      },
      {
        "_comment": "Nudge: prefer LSP symbol tools over Grep/Glob for code navigation (advisory, exit 0)",
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/enforce-lsp-navigation.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/post-format-and-heal.sh",
            "timeout": 60000
          }
        ]
      },
      {
        "_comment": "Auto lint-then-fix: runs linter on changed file, exits 2 with errors so Claude auto-fixes",
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lint-fix.js",
            "timeout": 15000
          }
        ]
      },
      {
        "_comment_lsp": "Compress verbose Serena MCP output before it hits agent context (like lean-ctx but for LSP). Uses PostToolUse.updatedMCPToolOutput. Pairs well with lean-ctx if you also install that — they don't overlap.",
        "matcher": "mcp__serena__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/compress-lsp-output.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "_comment": "Morae Power BI brand/JSON validation. Only active when MORAE_POWERBI_VALIDATION=1.",
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/morae-powerbi-validate.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/pre-compact-checkpoint.sh",
            "statusMessage": "Saving checkpoint before compaction..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "_comment": "Test gate — prevent stopping if uncommitted changes, TODO markers, or test failures exist",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/stop-gate.js",
            "timeout": 35000
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
