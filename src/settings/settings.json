{
  "model": "claude-sonnet-4-6",
  "maxTurns": 200,
  "effortLevel": "medium",

  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },

  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash list*)",
      "Bash(git remote *)",
      "Bash(rtk *)",
      "Bash(ls *)",
      "Bash(cat package.json)",
      "Bash(cat pyproject.toml)",
      "Bash(node --version)",
      "Bash(python --version)",
      "Bash(npm --version)",
      "Bash(pnpm --version)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(npm publish *)",
      "Bash(cargo publish *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(curl * | sh)",
      "Bash(dd if=*)",
      "Bash(chmod -R 777 *)",
      "Bash(mkfs.*)"
    ]
  },

  "worktree": {
    "symlinkDirectories": ["node_modules", ".next", "dist", "build", "__pycache__", ".venv"]
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-start.js",
            "statusMessage": "Loading session context..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-end.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__desktop-commander__start_process",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/pre-tool-use.js"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lsp-first-guard.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/bash-grep-block.js"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lsp-first-read-guard.js"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lsp-pre-delegation.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/post-tool-use.js"
          }
        ]
      },
      {
        "matcher": "mcp__cclsp__find_definition|mcp__cclsp__find_references|mcp__cclsp__find_workspace_symbols|mcp__cclsp__find_implementation|mcp__cclsp__get_hover|mcp__cclsp__get_diagnostics|mcp__cclsp__get_incoming_calls|mcp__cclsp__get_outgoing_calls",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lsp-usage-tracker.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/build-checker.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/error-handling-reminder.js"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/post-tool-use-failure.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/prompt-submit.js"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/permission-request.js"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/permission-denied.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/pre-compact.js"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/post-compact.js",
            "statusMessage": "Re-loading context after compaction..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/subagent-stop.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-end.js"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/worktree-create.js",
            "timeout": 30000,
            "statusMessage": "Setting up isolated worktree..."
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "package.json|pyproject.toml|requirements.txt|Cargo.toml|go.mod|.env.example",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/file-changed.js"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/config-change.js"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/instructions-loaded.js"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/cwd-changed.js"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/notification-idle.js"
          }
        ]
      }
    ]
  }
}
