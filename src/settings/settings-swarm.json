{
  "_comment": "claude-solo swarm settings. Merge into your settings.json to enable swarm hooks. These extend (not replace) the base claude-solo hooks.",

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_SOLO_SWARM_GATE": "0"
  },

  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/swarm/subagent-start.js"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/swarm/teammate-idle.js"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/swarm/task-created.js"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/swarm/task-completed.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/swarm/stop-gate.js"
          }
        ]
      }
    ]
  }
}
