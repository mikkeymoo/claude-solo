{
  "frontend-dev-guidelines": {
    "description": "React + MUI frontend conventions",
    "priority": 5,
    "enforcement": "suggest",
    "promptTriggers": {
      "keywords": ["react", "component", "mui", "tanstack", "frontend"],
      "intentPatterns": ["(create|update).*component", "(style|layout).*page", "(query|mutation).*frontend"]
    },
    "fileTriggers": {
      "pathPatterns": ["frontend/src/**/*.{ts,tsx,js,jsx}", "apps/frontend/**/*.{ts,tsx}"],
      "contentPatterns": ["from '@mui/", "useQuery", "createFileRoute"]
    }
  },
  "backend-dev-guidelines": {
    "description": "Node service layering and Prisma usage",
    "priority": 5,
    "enforcement": "suggest",
    "promptTriggers": {
      "keywords": ["controller", "service", "repository", "prisma", "endpoint"],
      "intentPatterns": ["(add|update).*endpoint", "(write|refactor).*service", "(transaction|prisma)"]
    },
    "fileTriggers": {
      "pathPatterns": ["services/backend/**/*.{ts,js}", "backend/src/**/*.{ts,js}"],
      "contentPatterns": ["from '@prisma/client'", "fastify", "DomainError"]
    }
  },
  "workflow-developer": {
    "description": "Workflow engine state/handler rules",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["workflow", "state machine", "transition", "handler"],
      "intentPatterns": ["(add|modify).*workflow", "(queue|schedule).*transition"]
    },
    "fileTriggers": {
      "pathPatterns": ["services/workflow/**/*.{ts,js,json}"],
      "contentPatterns": ["createWorkflow", "statechart", "workflow.transition"]
    }
  },
  "notification-developer": {
    "description": "Notification templates and channel logic",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["notification", "email", "sms", "template", "mjml"],
      "intentPatterns": ["(send|render).*notification", "(create|update).*template"]
    },
    "fileTriggers": {
      "pathPatterns": ["services/notification/**/*", "templates/notifications/**/*"],
      "contentPatterns": ["mjml", "notificationPreferences", "sendNotification"]
    }
  },
  "database-verification": {
    "description": "Enforced checks for schema/migration edits",
    "priority": 5,
    "enforcement": "block",
    "blockMessage": "⚠️ DATABASE SCHEMA MODIFICATION DETECTED!\n\nThis operation modifies the database schema. The database-verification skill MUST be engaged to:\n\n1. Review migration safety (no data loss)\n2. Check for rollback procedures\n3. Verify prisma schema consistency\n4. Validate foreign key constraints\n5. Ensure backward compatibility\n\nPlease use the database-verification skill before proceeding, or add @skip-validation:database-verification to your file.",
    "promptTriggers": {
      "keywords": ["migration", "schema", "prisma", "database"],
      "intentPatterns": ["drop column", "alter table", "change schema", "prisma schema"]
    },
    "fileTriggers": {
      "pathPatterns": ["prisma/**/*", "migrations/**/*.{sql,ts}", "services/**/repository/**/*.{ts,js}"],
      "contentPatterns": ["ALTER TABLE", "DROP COLUMN", "schema.prisma"]
    }
  },
  "skill-developer": {
    "description": "Meta guidance for crafting new skills",
    "priority": 3,
    "promptTriggers": {
      "keywords": ["skill", "guideline", "documentation"],
      "intentPatterns": ["create skill", "update skill", "refine skill"]
    }
  },
  "code-review": {
    "description": "Activates for code review requests",
    "priority": 3,
    "promptTriggers": {
      "keywords": ["review", "code review", "check code", "analyze code"],
      "intentPatterns": ["review.*code", "analyze.*changes", "feedback on implementation"]
    }
  },
  "build-fix": {
    "description": "Build and compilation troubleshooting",
    "priority": 5,
    "enforcement": "suggest",
    "promptTriggers": {
      "keywords": ["build error", "typescript error", "compile", "build failed"],
      "intentPatterns": ["(build|compile).*error", "typescript.*fail", "tsc.*error"]
    }
  },
  "test-runner": {
    "description": "Test execution helpers",
    "priority": 3,
    "promptTriggers": {
      "keywords": ["run tests", "jest", "vitest", "testing"],
      "intentPatterns": ["run.*test", "execute.*suite"]
    }
  },
  "documentation": {
    "description": "Documentation authoring assistance",
    "priority": 2,
    "promptTriggers": {
      "keywords": ["document", "docs", "readme", "write documentation"],
      "intentPatterns": ["write.*documentation", "update.*docs"]
    }
  },
  "refactor": {
    "description": "Refactoring guidance",
    "priority": 3,
    "promptTriggers": {
      "keywords": ["refactor", "improve code", "clean up"],
      "intentPatterns": ["refactor.*code", "optimize.*performance"]
    }
  },
  "debug": {
    "description": "Debugging assistance",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["debug", "fix bug", "not working", "troubleshoot"],
      "intentPatterns": ["debug.*issue", "fix.*bug"]
    }
  },
  "security-audit": {
    "description": "Security review guidance",
    "priority": 5,
    "enforcement": "warn",
    "blockMessage": "⚠️ SECURITY-SENSITIVE OPERATION DETECTED!\n\nThis operation involves:\n- Authentication/Authorization logic\n- Data encryption/decryption\n- User credentials handling\n- Database queries with user input\n- API endpoint security\n\nSTRONGLY RECOMMENDED: Engage security-audit skill to review for:\n- SQL injection vulnerabilities\n- XSS attack vectors\n- CSRF protection\n- Authentication bypass risks\n- Authorization flaws\n- Sensitive data exposure\n\nYou may proceed, but security review is highly recommended.",
    "promptTriggers": {
      "keywords": ["security", "vulnerability", "audit", "penetration", "authentication", "authorization", "encrypt", "decrypt", "password", "token", "jwt", "session"],
      "intentPatterns": ["security.*audit", "check.*vulnerability", "auth.*implementation", "encrypt.*data"]
    }
  },
  "performance": {
    "description": "Performance tuning",
    "priority": 3,
    "promptTriggers": {
      "keywords": ["performance", "optimize", "slow", "profiling"],
      "intentPatterns": ["improve.*performance", "profile.*code"]
    }
  },
  "api-integration": {
    "description": "API integration patterns",
    "priority": 3,
    "promptTriggers": {
      "keywords": ["api", "endpoint", "rest", "graphql", "integration"],
      "intentPatterns": ["integrate.*api", "create.*endpoint"]
    }
  },
  "database": {
    "description": "Database query and migration guidance",
    "priority": 3,
    "promptTriggers": {
      "keywords": ["database", "sql", "query", "migration"],
      "intentPatterns": ["database.*query", "sql.*optimization", "create.*migration"]
    }
  },
  "ui-design": {
    "description": "UI/UX design considerations",
    "priority": 2,
    "promptTriggers": {
      "keywords": ["ui", "ux", "design", "layout", "styling"],
      "intentPatterns": ["design.*interface", "create.*layout"]
    }
  },
  "deployment": {
    "description": "Deployment & CI/CD",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["deploy", "deployment", "ci/cd", "docker", "kubernetes"],
      "intentPatterns": ["deploy.*application", "configure.*ci"]
    }
  },
  "typescript-developer": {
    "description": "TypeScript/JavaScript development patterns",
    "priority": 5,
    "enforcement": "suggest",
    "promptTriggers": {
      "keywords": ["typescript", "javascript", "ts", "js", "node", "react", "vue", "angular", "express", "nestjs", "webpack", "jest", "npm"],
      "intentPatterns": ["typescript.*code", "javascript.*development", "async.*await", "promise"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "tsconfig.json", "package.json"],
      "contentPatterns": ["import.*from", "export", "async function", "await", "Promise"]
    }
  },
  "java-developer": {
    "description": "Java/Spring Boot development patterns",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["java", "spring", "springboot", "maven", "gradle", "junit", "jpa", "hibernate", "lombok"],
      "intentPatterns": ["java.*code", "spring.*boot", "maven.*build", "junit.*test"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.java", "pom.xml", "build.gradle", "application.properties"],
      "contentPatterns": ["@Service", "@Repository", "@Controller", "@SpringBootApplication"]
    }
  },
  "csharp-developer": {
    "description": "C# / .NET development patterns",
    "priority": 3,
    "promptTriggers": {
      "keywords": ["csharp", "c#", "dotnet", ".net", "asp.net", "entity-framework", "linq"],
      "intentPatterns": ["csharp.*code", "\\.net.*application", "entity.*framework"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.cs", "**/*.csproj", "appsettings.json"],
      "contentPatterns": ["using System", "public class", "[Serializable]"]
    }
  },
  "python-developer": {
    "description": "Python development patterns including async/await",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["python", "asyncio", "async", "await", "django", "flask", "fastapi", "pytest", "pydantic", "numpy", "pandas"],
      "intentPatterns": ["python.*code", "async.*python", "asyncio", "pytest.*test", "django.*model"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.py", "requirements.txt", "setup.py", "pyproject.toml", "Pipfile"],
      "contentPatterns": ["import asyncio", "async def", "await", "from fastapi", "import pytest"]
    },
    "resources": ["references/best-practices.md", "references/async-patterns.md"]
  },
  "powershell-developer": {
    "description": "PowerShell scripting patterns and automation",
    "priority": 3,
    "promptTriggers": {
      "keywords": ["powershell", "ps1", "pwsh", "cmdlet", "pipeline", "module", "automation"],
      "intentPatterns": ["powershell.*script", "ps1.*automation", "cmdlet.*function"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.ps1", "**/*.psm1", "**/*.psd1"],
      "contentPatterns": ["[CmdletBinding()]", "param(", "Write-Verbose", "function"]
    },
    "resources": ["references/scripting-patterns.md"]
  },
  "sql-developer": {
    "description": "Microsoft SQL Server query optimization and database design",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["sql", "sql server", "mssql", "t-sql", "query", "database", "optimization", "index", "join", "stored procedure", "cross apply"],
      "intentPatterns": ["sql.*query", "sql server.*optimization", "query.*performance", "create.*index", "stored.*procedure"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.sql", "migrations/**/*", "database/**/*"],
      "contentPatterns": ["SELECT", "INSERT", "UPDATE", "DELETE", "CREATE INDEX", "JOIN", "CROSS APPLY", "SET NOCOUNT"]
    },
    "resources": ["references/optimization-guide.md", "references/query-optimization.md", "examples/complex-queries.sql"]
  },
  "api-design-agent": {
    "description": "RESTful and GraphQL API design patterns",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["api design", "rest api", "graphql", "openapi", "swagger", "api versioning", "endpoint design"],
      "intentPatterns": ["design.*api", "create.*endpoint", "api.*architecture", "graphql.*schema"]
    }
  },
  "performance-monitor": {
    "description": "Performance monitoring and metrics tracking",
    "priority": 3,
    "promptTriggers": {
      "keywords": ["performance monitor", "metrics", "build time", "bundle size", "memory usage"],
      "intentPatterns": ["monitor.*performance", "track.*metrics", "analyze.*build"]
    }
  },
  "frontend-testing": {
    "description": "Frontend testing with React Testing Library, Vue Test Utils, and Playwright",
    "priority": 5,
    "enforcement": "suggest",
    "promptTriggers": {
      "keywords": ["frontend test", "react testing", "vue testing", "angular testing", "e2e test", "cypress", "playwright", "jest", "vitest", "testing library", "component test"],
      "intentPatterns": ["test.*component", "e2e.*test", "frontend.*testing", "playwright.*test", "cypress.*test"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.test.{ts,tsx,js,jsx}", "**/*.spec.{ts,tsx,js,jsx}", "e2e/**/*", "tests/**/*"],
      "contentPatterns": ["@testing-library", "describe(", "it(", "test(", "@vue/test-utils", "playwright"]
    }
  },
  "go-developer": {
    "description": "Go development with concurrency patterns, interfaces, and error handling",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["go", "golang", "goroutine", "channel", "go concurrency", "go interface", "go error", "go test"],
      "intentPatterns": ["go.*code", "golang.*development", "goroutine", "channel.*pattern"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.go", "go.mod", "go.sum"],
      "contentPatterns": ["package main", "func ", "go ", "import ("]
    }
  },
  "memory-leak-detector": {
    "description": "Memory leak detection and heap analysis",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["memory leak", "heap snapshot", "memory growth", "out of memory", "oom", "garbage collection"],
      "intentPatterns": ["detect.*memory.*leak", "analyze.*heap", "memory.*profiling"]
    }
  },
  "circular-dependency-resolver": {
    "description": "Circular dependency detection and resolution",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["circular dependency", "circular import", "module cycle", "dependency cycle", "import cycle"],
      "intentPatterns": ["circular.*dependency", "resolve.*cycle", "dependency.*graph"]
    }
  },
  "type-error-analyzer": {
    "description": "TypeScript type error analysis and resolution",
    "priority": 5,
    "enforcement": "suggest",
    "promptTriggers": {
      "keywords": ["type error", "typescript error", "type mismatch", "cannot assign", "property does not exist", "type inference"],
      "intentPatterns": ["type.*error", "typescript.*error", "type.*mismatch"]
    }
  },
  "performance-bottleneck-finder": {
    "description": "Performance bottleneck identification and optimization",
    "priority": 4,
    "promptTriggers": {
      "keywords": ["performance bottleneck", "slow query", "high latency", "render performance", "optimization", "profiling"],
      "intentPatterns": ["performance.*bottleneck", "slow.*query", "optimize.*performance"]
    }
  },
  "error-tracking": {
    "description": "Sentry integration and error monitoring patterns",
    "priority": 4,
    "enforcement": "suggest",
    "promptTriggers": {
      "keywords": ["sentry", "error tracking", "error monitoring", "exception", "capture error", "error handling", "production errors", "error reporting"],
      "intentPatterns": ["sentry.*integration", "error.*monitoring", "track.*error", "capture.*exception", "error.*reporting"]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.ts", "**/*.js", "**/*.tsx", "**/*.jsx"],
      "contentPatterns": ["Sentry.captureException", "@sentry/", "instrument.ts", "captureException", "Sentry.init"]
    }
  }
}
